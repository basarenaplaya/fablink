# Add directories or file patterns to ignore during indexing (e.g. foo/ or *.csv)
# ==========================================
# Dependencies & Build Outputs (High Noise)
# ==========================================
node_modules/
.next/
out/
build/
dist/
.cache/
.parcel-cache/

# ==========================================
# Version Control & OS Files
# ==========================================
.git/
.github/
.svn/
.hg/
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Firebase Cache & Debug Logs
# ==========================================
.firebase/
*_debug.log
firebase-debug.log
firestore-debug.log
ui-debug.log

# ==========================================
# Security & Credentials (Crucial to Ignore)
# ==========================================

*.pem
*.key
*.p12
service-account.json

# ==========================================
# System Logs & Package Manager Caches
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.pnpm-store/